<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="]n?Y9O=D$#t;p)WexjL," x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="c#qQy$=MHwDo-3v]Ba*u"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum NeopixelMode {&#13;" line1="    GRB = 1,&#13;" line2="    RGBW = 2,&#13;" line3="    RGB = 3&#13;" line4="}" numlines="5"></mutation><next><block type="typescript_statement" id="5(3uiq:Q~FHMFK{=el{3"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Ledstrip {&#13;" line1="&#13;" line2="    export class Device {&#13;" line3="&#13;" line4="        pin: DigitalPin&#13;" line5="        max: number&#13;" line6="        mode: NeopixelMode&#13;" line7="        buffer: Buffer&#13;" line8="        size: number&#13;" line9="        bright: number = 10&#13;" line10="&#13;" line11="        constructor(pin: DigitalPin, leds: number, mode: NeopixelMode) {&#13;" line12="            this.pin = pin&#13;" line13="            this.max = leds - 1&#13;" line14="            this.mode = mode&#13;" line15="            this.size = leds * (mode == NeopixelMode.RGBW ? 4 : 3)&#13;" line16="            this.buffer = pins.createBuffer(this.size)&#13;" line17="        }&#13;" line18="&#13;" line19="        show() {&#13;" line20="            light.sendWS2812Buffer(this.buffer, this.pin)&#13;" line21="        }&#13;" line22="&#13;" line23="        setPixelRGB(offset: number, red: number, green: number, blue: number, white: number = 0): void {&#13;" line24="            offset *= (this.mode == NeopixelMode.RGBW ? 4 : 3)&#13;" line25="            switch (this.mode) {&#13;" line26="                case NeopixelMode.GRB:&#13;" line27="                    this.buffer[offset + 0] = Math.floor(green * this.bright / 100)&#13;" line28="                    this.buffer[offset + 1] = Math.floor(red * this.bright / 100);&#13;" line29="                    this.buffer[offset + 2] = Math.floor(blue * this.bright / 100);&#13;" line30="                    break;&#13;" line31="                case NeopixelMode.RGB:&#13;" line32="                    this.buffer[offset + 0] = Math.floor(red * this.bright / 100);&#13;" line33="                    this.buffer[offset + 1] = Math.floor(green * this.bright / 100);&#13;" line34="                    this.buffer[offset + 2] = Math.floor(blue * this.bright / 100);&#13;" line35="                    break;&#13;" line36="                case NeopixelMode.RGBW:&#13;" line37="                    this.buffer[offset + 0] = Math.floor(red * this.bright / 100);&#13;" line38="                    this.buffer[offset + 1] = Math.floor(green * this.bright / 100);&#13;" line39="                    this.buffer[offset + 2] = Math.floor(blue * this.bright / 100);&#13;" line40="                    this.buffer[offset + 3] = Math.floor(white * this.bright / 100);&#13;" line41="                    break;&#13;" line42="            }&#13;" line43="        }&#13;" line44="&#13;" line45="        setPixelColor(pixel: number, color: Color, white: number = 0): void {&#13;" line46="            if (pixel &lt; 0 || pixel &gt;= 8)&#13;" line47="                return;&#13;" line48="            let rgb = fromColor(color)&#13;" line49="            let red = (rgb &gt;&gt; 16) &amp; 0xFF;&#13;" line50="            let green = (rgb &gt;&gt; 8) &amp; 0xFF;&#13;" line51="            let blue = (rgb) &amp; 0xFF;&#13;" line52="            this.setPixelRGB(pixel, red, green, blue, white)&#13;" line53="        }&#13;" line54="&#13;" line55="        setRGB(red: number, green: number, blue: number, white: number = 0) {&#13;" line56="            for (let i = 0; i &lt; 8; ++i)&#13;" line57="                this.setPixelRGB(i, red, green, blue, white)&#13;" line58="        }&#13;" line59="&#13;" line60="        setColor(color: Color, white: number = 0) {&#13;" line61="            let rgb2 = fromColor(color)&#13;" line62="            let red2 = (rgb2 &gt;&gt; 16) &amp; 0xFF;&#13;" line63="            let green2 = (rgb2 &gt;&gt; 8) &amp; 0xFF;&#13;" line64="            let blue2 = (rgb2) &amp; 0xFF;&#13;" line65="            for (let j = 0; j &lt; 8; ++j)&#13;" line66="                this.setPixelRGB(j, red2, green2, blue2, white)&#13;" line67="        }&#13;" line68="&#13;" line69="        setClear(): void {&#13;" line70="            this.buffer.fill(0, 0, this.size);&#13;" line71="        }&#13;" line72="&#13;" line73="        setBrightness(brightness: number) {&#13;" line74="            if (brightness &lt; 0) brightness = 0&#13;" line75="            if (brightness &gt; 100) brightness = 100&#13;" line76="            // small steps at low brightness and big steps at high brightness&#13;" line77="            brightness = (brightness ^ 2 / 100)&#13;" line78="            this.bright = brightness&#13;" line79="        }&#13;" line80="&#13;" line81="        setRotate(rotation: Rotate): void {&#13;" line82="            let offset = (this.mode == NeopixelMode.RGBW ? 4 : 3)&#13;" line83="            if (rotation == Rotate.Clockwise)&#13;" line84="                this.buffer.rotate(-offset, 0, this.size)&#13;" line85="            else&#13;" line86="                this.buffer.rotate(offset, 0, this.size)&#13;" line87="        }&#13;" line88="&#13;" line89="        rainbow(rotation: Rotate, pace: Pace = Pace.Normal) {&#13;" line90="            if (rotation == Rotate.Clockwise) {&#13;" line91="                this.setPixelColor(0, Color.Red)&#13;" line92="                this.setPixelColor(1, Color.Orange)&#13;" line93="                this.setPixelColor(2, Color.Yellow)&#13;" line94="                this.setPixelColor(3, Color.Green)&#13;" line95="                this.setPixelColor(4, Color.Blue)&#13;" line96="                this.setPixelColor(5, Color.Indigo)&#13;" line97="                this.setPixelColor(6, Color.Violet)&#13;" line98="                this.setPixelColor(7, Color.Purple)&#13;" line99="            }&#13;" line100="            else {&#13;" line101="                this.setPixelColor(7, Color.Red)&#13;" line102="                this.setPixelColor(6, Color.Orange)&#13;" line103="                this.setPixelColor(5, Color.Yellow)&#13;" line104="                this.setPixelColor(4, Color.Green)&#13;" line105="                this.setPixelColor(3, Color.Blue)&#13;" line106="                this.setPixelColor(2, Color.Indigo)&#13;" line107="                this.setPixelColor(1, Color.Violet)&#13;" line108="                this.setPixelColor(0, Color.Purple)&#13;" line109="            }&#13;" line110="            this.show()&#13;" line111="            basic.pause(pace)&#13;" line112="            pace = (pace + 1) * 75&#13;" line113="            for (let k = 0; k &lt; this.max; k++) {&#13;" line114="                this.setRotate(rotation)&#13;" line115="                this.show()&#13;" line116="                basic.pause(pace)&#13;" line117="            }&#13;" line118="        }&#13;" line119="&#13;" line120="        snake(color: Color, rotation: Rotate, pace: Pace = Pace.Normal) {&#13;" line121="            let rgb3 = fromColor(color)&#13;" line122="            let red3 = (rgb3 &gt;&gt; 16) &amp; 0xFF;&#13;" line123="            let green3 = (rgb3 &gt;&gt; 8) &amp; 0xFF;&#13;" line124="            let blue3 = (rgb3) &amp; 0xFF;&#13;" line125="            this.setClear();&#13;" line126="            this.show()&#13;" line127="            pace = (pace + 1) * 75&#13;" line128="            for (let l = this.max; l &gt;= 0; l--) {&#13;" line129="                if (rotation == Rotate.Clockwise)&#13;" line130="                    this.setPixelRGB(this.max - l, red3, green3, blue3)&#13;" line131="                else&#13;" line132="                    this.setPixelRGB(l, red3, green3, blue3)&#13;" line133="                this.show()&#13;" line134="                basic.pause(pace)&#13;" line135="            }&#13;" line136="            this.show()&#13;" line137="            for (let m = this.max - 1; m &gt;= 0; m--) {&#13;" line138="                if (rotation == Rotate.Clockwise)&#13;" line139="                    this.setPixelRGB(this.max - m, 0, 0, 0)&#13;" line140="                else&#13;" line141="                    this.setPixelRGB(m, 0, 0, 0)&#13;" line142="                this.show()&#13;" line143="                basic.pause(pace)&#13;" line144="            }&#13;" line145="            if (rotation == Rotate.Clockwise)&#13;" line146="                this.setPixelRGB(0, 0, 0, 0)&#13;" line147="            else&#13;" line148="                this.setPixelRGB(this.max, 0, 0, 0)&#13;" line149="            this.show()&#13;" line150="            basic.pause(pace)&#13;" line151="        }&#13;" line152="    }&#13;" line153="&#13;" line154="    export function create(pin: DigitalPin, leds: number, mode: NeopixelMode = NeopixelMode.GRB): Device {&#13;" line155="        let device = new Device(pin, leds, mode)&#13;" line156="        return device&#13;" line157="    }&#13;" line158="}" numlines="159"></mutation><next><block type="typescript_statement" id="(S,veeO_+G:b=f|aFr}L"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let elementHandler: handler" numlines="1" declaredvars="elementHandler"></mutation><next><block type="typescript_statement" id="MUhcHkTA=y5~GmQ^Z~8-"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace Intelino {&#13;" line1="&#13;" line2="    // per gate there are 2 positions of max 3 leds each&#13;" line3="    let leds: Ledstrip.Device[] = []&#13;" line4="    leds.push(Ledstrip.create(DigitalPin.P0, 6))&#13;" line5="    leds.push(Ledstrip.create(DigitalPin.P1, 6))&#13;" line6="    leds.push(Ledstrip.create(DigitalPin.P2, 6))&#13;" line7="    leds.push(Ledstrip.create(DigitalPin.P13, 6))&#13;" line8="    leds.push(Ledstrip.create(DigitalPin.P14, 6))&#13;" line9="    leds.push(Ledstrip.create(DigitalPin.P15, 6))&#13;" line10="&#13;" line11="    export enum Id {&#13;" line12="        //% block=&quot;1&quot;&#13;" line13="        //% block.loc.nl=&quot;1&quot;&#13;" line14="        Id1 = 1,&#13;" line15="        //% block=&quot;2&quot;&#13;" line16="        //% block.loc.nl=&quot;2&quot;&#13;" line17="        Id2 = 2,&#13;" line18="        //% block=&quot;3&quot;&#13;" line19="        //% block.loc.nl=&quot;3&quot;&#13;" line20="        Id3 = 3,&#13;" line21="        //% block=&quot;4&quot;&#13;" line22="        //% block.loc.nl=&quot;4&quot;&#13;" line23="        Id4 = 4,&#13;" line24="        //% block=&quot;5&quot;&#13;" line25="        //% block.loc.nl=&quot;5&quot;&#13;" line26="        Id5 = 5,&#13;" line27="        //% block=&quot;6&quot;&#13;" line28="        //% block.loc.nl=&quot;6&quot;&#13;" line29="        Id6 = 6,&#13;" line30="        //% block=&quot;7&quot;&#13;" line31="        //% block.loc.nl=&quot;7&quot;&#13;" line32="        Id7 = 7,&#13;" line33="        //% block=&quot;8&quot;&#13;" line34="        //% block.loc.nl=&quot;8&quot;&#13;" line35="        Id8 = 8,&#13;" line36="        //% block=&quot;9&quot;&#13;" line37="        //% block.loc.nl=&quot;9&quot;&#13;" line38="        Id9 = 9,&#13;" line39="        //% block=&quot;10&quot;&#13;" line40="        //% block.loc.nl=&quot;10&quot;&#13;" line41="        Id10 = 10,&#13;" line42="        //% block=&quot;11&quot;&#13;" line43="        //% block.loc.nl=&quot;11&quot;&#13;" line44="        Id11 = 11,&#13;" line45="        //% block=&quot;12&quot;&#13;" line46="        //% block.loc.nl=&quot;12&quot;&#13;" line47="        Id12 = 12,&#13;" line48="    }&#13;" line49="&#13;" line50="    export enum Gate {&#13;" line51="        //% block=&quot;gate A&quot;&#13;" line52="        //% block.loc.nl=&quot;poort A&quot;&#13;" line53="        Gate1,&#13;" line54="        //% block=&quot;gate B&quot;&#13;" line55="        //% block.loc.nl=&quot;poort B&quot;&#13;" line56="        Gate2,&#13;" line57="        //% block=&quot;gate C&quot;&#13;" line58="        //% block.loc.nl=&quot;poort C&quot;&#13;" line59="        Gate3,&#13;" line60="        //% block=&quot;gate D&quot;&#13;" line61="        //% block.loc.nl=&quot;poort D&quot;&#13;" line62="        Gate4,&#13;" line63="        //% block=&quot;gate E&quot;&#13;" line64="        //% block.loc.nl=&quot;poort E&quot;&#13;" line65="        Gate5,&#13;" line66="        //% block=&quot;gate F&quot;&#13;" line67="        //% block.loc.nl=&quot;poort 7&quot;&#13;" line68="        Gate6,&#13;" line69="    }&#13;" line70="&#13;" line71="    export enum Position {&#13;" line72="        //% block=&quot;line I&quot;&#13;" line73="        //% block.loc.nl=&quot;lijn I&quot;&#13;" line74="        Position1,&#13;" line75="        //% block=&quot;line II&quot;&#13;" line76="        //% block.loc.nl=&quot;lijn II&quot;&#13;" line77="        Position2,&#13;" line78="    }&#13;" line79="&#13;" line80="    export enum Type {&#13;" line81="        //% block=&quot;speed control&quot;&#13;" line82="        //% block.loc.nl=&quot;snelheidsregelaar&quot;&#13;" line83="        Speed,&#13;" line84="        //% block=&quot;stopping place&quot;&#13;" line85="        //% block.loc.nl=&quot;halte&quot;&#13;" line86="        Wait,&#13;" line87="        //% block=&quot;switch to the left&quot;&#13;" line88="        //% block.loc.nl=&quot;wissel naar links&quot;&#13;" line89="        SwitchLeft,&#13;" line90="        //% block=&quot;switch to the right&quot;&#13;" line91="        //% block.loc.nl=&quot;wissel naar rechts&quot;&#13;" line92="        SwitchRight,&#13;" line93="        //% block=&quot;uncoupler&quot;&#13;" line94="        //% block.loc.nl=&quot;ontkoppelaar&quot;&#13;" line95="        Uncouple,&#13;" line96="        //% block=&quot;uturn&quot;&#13;" line97="        //% block.loc.nl=&quot;omkering&quot;&#13;" line98="        Uturn,&#13;" line99="    }&#13;" line100="&#13;" line101="    export enum State {&#13;" line102="        //% block=&quot;off&quot;&#13;" line103="        //% block.loc.nl=&quot;uit&quot;&#13;" line104="        Inactive = 0,&#13;" line105="        //% block=&quot;on&quot;&#13;" line106="        //% block.loc.nl=&quot;aan&quot;&#13;" line107="        Active = 1,&#13;" line108="        //% block=&quot;normal&quot;&#13;" line109="        //% block.loc.nl=&quot;normaal&quot;&#13;" line110="        Normal = 2,&#13;" line111="        //% block=&quot;slow&quot;&#13;" line112="        //% block.loc.nl=&quot;langzaam&quot;&#13;" line113="        Slow = 1,&#13;" line114="        //% block=&quot;fast&quot;&#13;" line115="        //% block.loc.nl=&quot;snel&quot;&#13;" line116="        Fast = 3,&#13;" line117="        //% block=&quot;short&quot;&#13;" line118="        //% block.loc.nl=&quot;kort&quot;&#13;" line119="        Short = 1,&#13;" line120="        //% block=&quot;long&quot;&#13;" line121="        //% block.loc.nl=&quot;lang&quot;&#13;" line122="        Long = 3,&#13;" line123="        //% block=&quot;bent&quot;&#13;" line124="        //% block.loc.nl=&quot;afslaan&quot;&#13;" line125="        Bent = 1,&#13;" line126="        //% block=&quot;straight ahead&quot;&#13;" line127="        //% block.loc.nl=&quot;rechtdoor&quot;&#13;" line128="        Straight = 2,&#13;" line129="    }&#13;" line130="&#13;" line131="    interface Element {&#13;" line132="        id: number&#13;" line133="        type: Type&#13;" line134="        state: State&#13;" line135="        gate: Gate&#13;" line136="        position: Position&#13;" line137="        offset: number&#13;" line138="        reverse: boolean&#13;" line139="    }&#13;" line140="    let elements: Element[] = []&#13;" line141="&#13;" line142="    radio.onReceivedNumber(function (key: number) {&#13;" line143="        if (elementHandler) elementHandler()&#13;" line144="    })&#13;" line145="&#13;" line146="    function setPixelOffset(gate: Gate) {&#13;" line147="        let typcnt = [3, 3, 1, 1, 1, 1] // number of pixels per element type&#13;" line148="        let offset2 = 0&#13;" line149="        for (let n = 0; n &lt; elements.length; n++) {&#13;" line150="            if (elements[n].gate == gate &amp;&amp; elements[n].position == Position.Position1) {&#13;" line151="                offset2 = typcnt[elements[n].type]&#13;" line152="                break&#13;" line153="            }&#13;" line154="        }&#13;" line155="        for (let o = 0; o &lt; elements.length; o++) {&#13;" line156="            if (elements[o].gate == gate &amp;&amp; elements[o].position == Position.Position2) {&#13;" line157="                elements[o].offset = offset2&#13;" line158="                break&#13;" line159="            }&#13;" line160="        }&#13;" line161="    }&#13;" line162="&#13;" line163="    function setSpeed(gate: Gate, pixel: number, state: State, reverse: boolean) {&#13;" line164="        leds[gate].setPixelColor(pixel, Color.Black)&#13;" line165="        leds[gate].setPixelColor(pixel + 1, Color.Black)&#13;" line166="        leds[gate].setPixelColor(pixel + 2, Color.Black)&#13;" line167="        if (reverse) {&#13;" line168="            switch (state) {&#13;" line169="                // no individual break after the next cases&#13;" line170="                case State.Fast: leds[gate].setPixelColor(pixel, Color.Green)&#13;" line171="                case State.Normal: leds[gate].setPixelColor(pixel + 1, Color.Green)&#13;" line172="                case State.Slow: leds[gate].setPixelColor(pixel + 2, Color.Green)&#13;" line173="                    break&#13;" line174="            }&#13;" line175="        }&#13;" line176="        else {&#13;" line177="            switch (state) {&#13;" line178="                // no individual break after the next cases&#13;" line179="                case State.Fast: leds[gate].setPixelColor(pixel + 2, Color.Green)&#13;" line180="                case State.Normal: leds[gate].setPixelColor(pixel + 1, Color.Green)&#13;" line181="                case State.Slow: leds[gate].setPixelColor(pixel, Color.Green)&#13;" line182="                    break&#13;" line183="            }&#13;" line184="        }&#13;" line185="        leds[gate].show()&#13;" line186="    }&#13;" line187="&#13;" line188="    function setWait(gate: Gate, pixel: number, state: State, reverse: boolean) {&#13;" line189="        leds[gate].setPixelColor(pixel, Color.Black)&#13;" line190="        leds[gate].setPixelColor(pixel + 1, Color.Black)&#13;" line191="        leds[gate].setPixelColor(pixel + 2, Color.Black)&#13;" line192="        if (reverse) {&#13;" line193="            switch (state) {&#13;" line194="                // no individual break after the next cases&#13;" line195="                case State.Long: leds[gate].setPixelColor(pixel, Color.Red)&#13;" line196="                case State.Normal: leds[gate].setPixelColor(pixel + 1, Color.Red)&#13;" line197="                case State.Short: leds[gate].setPixelColor(pixel + 2, Color.Red)&#13;" line198="                    break&#13;" line199="            }&#13;" line200="        }&#13;" line201="        else {&#13;" line202="            switch (state) {&#13;" line203="                // no individual break after the next cases&#13;" line204="                case State.Long: leds[gate].setPixelColor(pixel + 2, Color.Red)&#13;" line205="                case State.Normal: leds[gate].setPixelColor(pixel + 1, Color.Red)&#13;" line206="                case State.Short: leds[gate].setPixelColor(pixel, Color.Red)&#13;" line207="                    break&#13;" line208="            }&#13;" line209="        }&#13;" line210="        leds[gate].show()&#13;" line211="    }&#13;" line212="&#13;" line213="    function setSwitchLeft(gate: Gate, pixel: number, state: State) {&#13;" line214="        switch (state) {&#13;" line215="            case State.Inactive:&#13;" line216="                leds[gate].setPixelColor(pixel, Color.Black)&#13;" line217="                break&#13;" line218="            case State.Bent:&#13;" line219="                leds[gate].setPixelColor(pixel, Color.Red)&#13;" line220="                break&#13;" line221="            case State.Straight:&#13;" line222="                leds[gate].setPixelColor(pixel, Color.Green)&#13;" line223="                break&#13;" line224="        }&#13;" line225="        leds[gate].show()&#13;" line226="    }&#13;" line227="&#13;" line228="    function setSwitchRight(gate: Gate, pixel: number, state: State) {&#13;" line229="        switch (state) {&#13;" line230="            case State.Inactive:&#13;" line231="                leds[gate].setPixelColor(pixel, Color.Black)&#13;" line232="                break&#13;" line233="            case State.Bent:&#13;" line234="                leds[gate].setPixelColor(pixel, Color.Blue)&#13;" line235="                break&#13;" line236="            case State.Straight:&#13;" line237="                leds[gate].setPixelColor(pixel, Color.Green)&#13;" line238="                break&#13;" line239="        }&#13;" line240="        leds[gate].show()&#13;" line241="&#13;" line242="    }&#13;" line243="&#13;" line244="    function setUncouple(gate: Gate, pixel: number, state: State) {&#13;" line245="        switch (state) {&#13;" line246="            case State.Inactive:&#13;" line247="                leds[gate].setPixelColor(pixel, Color.Black)&#13;" line248="                break&#13;" line249="            case State.Active:&#13;" line250="                leds[gate].setPixelColor(pixel, Color.Yellow)&#13;" line251="                break&#13;" line252="        }&#13;" line253="        leds[gate].show()&#13;" line254="    }&#13;" line255="&#13;" line256="    function setUturn(gate: Gate, pixel: number, state: State) {&#13;" line257="        switch (state) {&#13;" line258="            case State.Inactive:&#13;" line259="                leds[gate].setPixelColor(pixel, Color.Black)&#13;" line260="                break&#13;" line261="            case State.Active:&#13;" line262="                leds[gate].setPixelColor(pixel, Color.Blue)&#13;" line263="                break&#13;" line264="        }&#13;" line265="        leds[gate].show()&#13;" line266="    }&#13;" line267="&#13;" line268="    function getNextState(type: Type, state: State): State {&#13;" line269="        state += 1&#13;" line270="        switch (type) {&#13;" line271="            case Type.Speed: if (state &lt; State.Slow || state &gt; State.Fast)&#13;" line272="                state = State.Slow&#13;" line273="                break&#13;" line274="            case Type.Wait: if (state &lt; State.Short || state &gt; State.Long)&#13;" line275="                state = State.Short&#13;" line276="                break&#13;" line277="            case Type.SwitchLeft:&#13;" line278="            case Type.SwitchRight: if (state &lt; State.Bent || state &gt; State.Straight)&#13;" line279="                state = State.Bent&#13;" line280="                break&#13;" line281="            case Type.Uncouple:&#13;" line282="            case Type.Uturn: if (state &lt; State.Inactive || state &gt; State.Active)&#13;" line283="                state = State.Inactive&#13;" line284="                break&#13;" line285="            default: state = State.Inactive&#13;" line286="        }&#13;" line287="        return state&#13;" line288="    }&#13;" line289="&#13;" line290="    function getId(id: number): number {&#13;" line291="        let p: number&#13;" line292="        for (p = 0; p &lt; elements.length; p++)&#13;" line293="            if (elements[p].id == id) break&#13;" line294="        if (p == elements.length)&#13;" line295="            elements.push({&#13;" line296="                id: id, type: Type.Speed, state: State.Inactive, gate: Gate.Gate1,&#13;" line297="                position: Position.Position1, offset: 0, reverse: false&#13;" line298="            })&#13;" line299="        return p&#13;" line300="    }&#13;" line301="&#13;" line302="    //% color=&quot;#FFCC00&quot;&#13;" line303="    //% block=&quot;when a command received&quot;&#13;" line304="    //% block.loc.nl=&quot;wanneer een opdracht is ontvangen&quot;&#13;" line305="    export function onOutOfField(code: () =&gt; void): void {&#13;" line306="        elementHandler = code&#13;" line307="    }&#13;" line308="&#13;" line309="    //% subcategory=&quot;Bediening&quot;&#13;" line310="    //% block=&quot;set uturn %id to state %state&quot;&#13;" line311="    //% block.loc.nl=&quot;zet omkeren %id in stand %state&quot;&#13;" line312="    export function idUturn(id: Id, state: State) {&#13;" line313="        let q = getId(id)&#13;" line314="        setUturn(elements[q].gate, elements[q].offset, elements[q].state)&#13;" line315="    }&#13;" line316="&#13;" line317="    //% subcategory=&quot;Bediening&quot;&#13;" line318="    //% block=&quot;set uncouple %id to state %state&quot;&#13;" line319="    //% block.loc.nl=&quot;zet loskoppelen %id in stand %state&quot;&#13;" line320="    export function idUncouple(id: Id, state: State) {&#13;" line321="        let r = getId(id)&#13;" line322="        setUncouple(elements[r].gate, elements[r].offset, elements[r].state)&#13;" line323="    }&#13;" line324="&#13;" line325="    //% subcategory=&quot;Bediening&quot;&#13;" line326="    //% block=&quot;set pause %id to state %state&quot;&#13;" line327="    //% block.loc.nl=&quot;zet pauzeer %id in stand %state&quot;&#13;" line328="    export function idWait(id: Id, state: State) {&#13;" line329="        let s = getId(id)&#13;" line330="        setWait(elements[s].gate, elements[s].offset, elements[s].state, elements[s].reverse)&#13;" line331="    }&#13;" line332="&#13;" line333="    //% subcategory=&quot;Bediening&quot;&#13;" line334="    //% block=&quot;set speed %id to state %state&quot;&#13;" line335="    //% block.loc.nl=&quot;zet snelheid %id in stand %state&quot;&#13;" line336="    export function idSpeed(id: Id, state: State) {&#13;" line337="        let t = getId(id)&#13;" line338="        setSpeed(elements[t].gate, elements[t].offset, elements[t].state, elements[t].reverse)&#13;" line339="    }&#13;" line340="&#13;" line341="    //% subcategory=&quot;Bediening&quot;&#13;" line342="    //% block=&quot;set switch %id to state %state&quot;&#13;" line343="    //% block.loc.nl=&quot;zet wissel %id in stand %state&quot;&#13;" line344="    export function idSwitch(id: Id, state: State) {&#13;" line345="        let u = getId(id)&#13;" line346="        if (elements[u].type == Type.SwitchLeft)&#13;" line347="            setSwitchLeft(elements[u].gate, elements[u].offset, elements[u].state)&#13;" line348="        else&#13;" line349="            setSwitchRight(elements[u].gate, elements[u].offset, elements[u].state)&#13;" line350="    }&#13;" line351="&#13;" line352="    //% block=&quot;set %id to state %state&quot;&#13;" line353="    //% block.loc.nl=&quot;zet %id in stand %state&quot;&#13;" line354="    export function idState(id: Id, state: State) {&#13;" line355="        let v = getId(id)&#13;" line356="        elements[v].state = state&#13;" line357="        switch (elements[v].type) {&#13;" line358="            case Type.Speed:&#13;" line359="                setSpeed(elements[v].gate, elements[v].offset, elements[v].state, elements[v].reverse)&#13;" line360="                break&#13;" line361="            case Type.Wait:&#13;" line362="                setWait(elements[v].gate, elements[v].offset, elements[v].state, elements[v].reverse)&#13;" line363="                break&#13;" line364="            case Type.SwitchLeft:&#13;" line365="                setSwitchLeft(elements[v].gate, elements[v].offset, elements[v].state)&#13;" line366="                break&#13;" line367="            case Type.SwitchRight:&#13;" line368="                setSwitchRight(elements[v].gate, elements[v].offset, elements[v].state)&#13;" line369="                break&#13;" line370="            case Type.Uncouple:&#13;" line371="                setUncouple(elements[v].gate, elements[v].offset, elements[v].state)&#13;" line372="                break&#13;" line373="            case Type.Uturn:&#13;" line374="                setUturn(elements[v].gate, elements[v].offset, elements[v].state)&#13;" line375="                break&#13;" line376="        }&#13;" line377="    }&#13;" line378="&#13;" line379="    //% block=&quot;set %id to the next state&quot;&#13;" line380="    //% block.loc.nl=&quot;zet %id in de volgende stand&quot;&#13;" line381="    export function idNextState(id: Id) {&#13;" line382="        let w = getId(id)&#13;" line383="        elements[w].state = getNextState(elements[w].type, elements[w].state)&#13;" line384="        switch (elements[w].type) {&#13;" line385="            case Type.Speed:&#13;" line386="                setSpeed(elements[w].gate, elements[w].offset, elements[w].state, elements[w].reverse)&#13;" line387="                break&#13;" line388="            case Type.Wait:&#13;" line389="                setWait(elements[w].gate, elements[w].offset, elements[w].state, elements[w].reverse)&#13;" line390="                break&#13;" line391="            case Type.SwitchLeft:&#13;" line392="                setSwitchLeft(elements[w].gate, elements[w].offset, elements[w].state)&#13;" line393="                break&#13;" line394="            case Type.SwitchRight:&#13;" line395="                setSwitchRight(elements[w].gate, elements[w].offset, elements[w].state)&#13;" line396="                break&#13;" line397="            case Type.Uncouple:&#13;" line398="                setUncouple(elements[w].gate, elements[w].offset, elements[w].state)&#13;" line399="                break&#13;" line400="            case Type.Uturn:&#13;" line401="                setUturn(elements[w].gate, elements[w].offset, elements[w].state)&#13;" line402="                break&#13;" line403="        }&#13;" line404="    }&#13;" line405="&#13;" line406="    //% block=&quot;turn all codes in opposite direction&quot;&#13;" line407="    //% block.loc.nl=&quot;draai alle codes in omgekeerde richting&quot;&#13;" line408="    function idInvertAll() {&#13;" line409="        for (let a = 0; a &lt; elements.length; a++) {&#13;" line410="            elements[a].reverse = !elements[a].reverse&#13;" line411="            idState(elements[a].id, elements[a].state)&#13;" line412="        }&#13;" line413="    }&#13;" line414="&#13;" line415="    //% block=&quot;turn %id in opposite direction&quot;&#13;" line416="    //% block.loc.nl=&quot;draai %id in omgekeerde richting&quot;&#13;" line417="    function idInvert(id: Id) {&#13;" line418="        let b = getId(id)&#13;" line419="        elements[b].reverse = !elements[b].reverse&#13;" line420="        idState(id, elements[b].state)&#13;" line421="    }&#13;" line422="&#13;" line423="    //% block=&quot;attach %id to gate %gate, line %position&quot;&#13;" line424="    //% block.loc.nl=&quot;verbind %id met poort %gate, lijn %position&quot;&#13;" line425="    export function idConnect(id: Id, gate: Gate, position: Position) {&#13;" line426="        let c = getId(id)&#13;" line427="        elements[c].gate = gate&#13;" line428="        elements[c].position = position&#13;" line429="        setPixelOffset(gate)&#13;" line430="    }&#13;" line431="&#13;" line432="    //% block=&quot;make %id to be a %type&quot;&#13;" line433="    //% block.loc.nl=&quot;maak van %id een %type&quot;&#13;" line434="    export function idType(id: Id, type: Type) {&#13;" line435="        let d = getId(id)&#13;" line436="        elements[d].type = type&#13;" line437="        setPixelOffset(elements[d].gate)&#13;" line438="    }&#13;" line439="}" numlines="440"></mutation></block></next></block></next></block></next></block></statement></block></xml>